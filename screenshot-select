#!/usr/bin/env python3
"""
Ubuntu Screenshot Tool — Windows-style region select screenshot.
Hotkey: Super+Shift+S

Captures a region of the screen, saves to ~/Screenshots/, and copies
the image to the clipboard for pasting into any application.

Dependencies: python3, python3-gi (GTK3), maim, xclip
All except xclip are pre-installed on Ubuntu.
"""

import os
import sys
import signal
import subprocess
import tempfile
from datetime import datetime

import gi
gi.require_version('Gtk', '3.0')
gi.require_version('Gdk', '3.0')
gi.require_version('GdkPixbuf', '2.0')
from gi.repository import Gtk, Gdk, GdkPixbuf, GLib

SCREENSHOT_DIR = os.path.expanduser("~/Screenshots")
MIN_DRAG = 5


def capture_screen():
    """Capture full screen with maim and create dimmed version in-memory."""
    tmp_fd, tmp = tempfile.mkstemp(suffix=".png")
    os.close(tmp_fd)
    try:
        subprocess.run(["maim", tmp],
                       check=True, timeout=5,
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        full = GdkPixbuf.Pixbuf.new_from_file(tmp)

        # Create dimmed version in-memory by compositing a semi-transparent black overlay
        dimmed = full.copy()
        black = GdkPixbuf.Pixbuf.new(GdkPixbuf.Colorspace.RGB, True, 8,
                                     full.get_width(), full.get_height())
        black.fill(0x00000099)
        black.composite(dimmed, 0, 0, full.get_width(), full.get_height(),
                        0, 0, 1.0, 1.0, GdkPixbuf.InterpType.NEAREST, 180)

        return full, dimmed
    except Exception as e:
        print(f"Failed to capture screen: {e}", file=sys.stderr)
        sys.exit(1)
    finally:
        try:
            os.unlink(tmp)
        except OSError:
            pass


class ScreenshotOverlay(Gtk.Window):
    def __init__(self, full_pixbuf, dim_pixbuf):
        super().__init__()

        self.full_pixbuf = full_pixbuf
        self.dim_pixbuf = dim_pixbuf
        self.screen_w = full_pixbuf.get_width()
        self.screen_h = full_pixbuf.get_height()

        self.start_x = self.start_y = 0
        self.cur_x = self.cur_y = 0
        self.dragging = False

        self.set_decorated(False)
        self.set_skip_taskbar_hint(True)
        self.set_skip_pager_hint(True)

        # Display pixbuf updated on each mouse move
        self.display_pixbuf = dim_pixbuf.copy()
        self.image = Gtk.Image.new_from_pixbuf(self.display_pixbuf)

        # EventBox to capture mouse events on the image
        self.ebox = Gtk.EventBox()
        self.ebox.set_events(
            Gdk.EventMask.BUTTON_PRESS_MASK |
            Gdk.EventMask.BUTTON_RELEASE_MASK |
            Gdk.EventMask.POINTER_MOTION_MASK
        )
        self.ebox.connect("button-press-event", self.on_button_press)
        self.ebox.connect("button-release-event", self.on_button_release)
        self.ebox.connect("motion-notify-event", self.on_motion)
        self.ebox.add(self.image)
        self.add(self.ebox)

        self.connect("key-press-event", self.on_key_press)
        self.connect("map-event", self.on_map)
        self.fullscreen()
        self.show_all()

    def on_map(self, widget, event):
        display = self.get_display()
        crosshair = Gdk.Cursor.new_from_name(display, "crosshair")
        self.get_window().set_cursor(crosshair)
        GLib.timeout_add(100, self._grab_input, crosshair)

    def _grab_input(self, cursor):
        seat = self.get_display().get_default_seat()
        status = seat.grab(self.get_window(), Gdk.SeatCapabilities.ALL, True,
                           cursor, None, None, None)
        if status != Gdk.GrabStatus.SUCCESS:
            GLib.timeout_add(50, self._grab_input, cursor)
        return False

    def _update_display(self):
        """Composite dimmed background + bright selection into display pixbuf."""
        self.dim_pixbuf.copy_area(0, 0, self.screen_w, self.screen_h,
                                  self.display_pixbuf, 0, 0)

        if self.dragging:
            x, y, w, h = self._get_rect()
            if w > 0 and h > 0:
                self.full_pixbuf.copy_area(x, y, w, h,
                                           self.display_pixbuf, x, y)

        self.image.set_from_pixbuf(self.display_pixbuf)

    def on_button_press(self, widget, event):
        if event.button == 1:
            self.start_x = int(event.x)
            self.start_y = int(event.y)
            self.cur_x = self.start_x
            self.cur_y = self.start_y
            self.dragging = True

    def on_motion(self, widget, event):
        if self.dragging:
            self.cur_x = int(event.x)
            self.cur_y = int(event.y)
            self._update_display()

    def on_button_release(self, widget, event):
        if event.button == 1 and self.dragging:
            self.dragging = False
            self.cur_x = int(event.x)
            self.cur_y = int(event.y)
            x, y, w, h = self._get_rect()
            if w >= MIN_DRAG and h >= MIN_DRAG:
                self.hide()
                GLib.idle_add(self._save_and_clip, x, y, w, h)
            else:
                Gtk.main_quit()

    def on_key_press(self, widget, event):
        if event.keyval == Gdk.KEY_Escape:
            Gtk.main_quit()

    def _get_rect(self):
        x = min(self.start_x, self.cur_x)
        y = min(self.start_y, self.cur_y)
        w = abs(self.cur_x - self.start_x)
        h = abs(self.cur_y - self.start_y)
        x = max(0, x)
        y = max(0, y)
        w = min(w, self.screen_w - x)
        h = min(h, self.screen_h - y)
        return x, y, w, h

    def _save_and_clip(self, x, y, w, h):
        cropped = GdkPixbuf.Pixbuf.new(GdkPixbuf.Colorspace.RGB, True, 8, w, h)
        self.full_pixbuf.copy_area(x, y, w, h, cropped, 0, 0)

        os.makedirs(SCREENSHOT_DIR, exist_ok=True)
        ts = datetime.now().strftime("%Y-%m-%d_%H-%M-%S")
        filepath = os.path.join(SCREENSHOT_DIR, f"screenshot-{ts}.png")
        cropped.savev(filepath, "png", [], [])

        # Copy image to clipboard via xclip
        try:
            subprocess.run(["xclip", "-selection", "clipboard",
                            "-t", "image/png", "-i", filepath],
                           check=True, timeout=5)
        except Exception as e:
            print(f"Clipboard error: {e}", file=sys.stderr)

        # Desktop notification
        try:
            subprocess.Popen(["notify-send", "-i", filepath,
                              "Screenshot saved", filepath],
                             stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except FileNotFoundError:
            pass

        print(filepath)
        Gtk.main_quit()
        return False


def main():
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    full, dimmed = capture_screen()
    ScreenshotOverlay(full, dimmed)
    Gtk.main()


if __name__ == "__main__":
    main()
